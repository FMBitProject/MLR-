# Copy to .env.local and fill in. .env* is gitignored.

# --- Database (required) ---
# Local dev (Docker Postgres):
#   DATABASE_URL=postgres://postgres:mlr@localhost:5433/mlr
# Production (Neon): use the POOLED connection string from the Neon dashboard,
# it ends in "-pooler" and includes ?sslmode=require
DATABASE_URL=

# Max connections per instance (Neon's pooler handles fan-out; keep this small)
# DB_POOL_MAX=5

# --- Auth (required in production) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- File storage ---
# Default (unset or STORAGE_DRIVER=db): uploaded files are stored inline in
# Postgres (content_versions.file_data) — no extra service needed, since
# uploads are capped at 20MB client-side.
# Set STORAGE_DRIVER=local only for quick local testing (writes to
# .data/uploads instead) — never durable on Vercel, dev use only.
# STORAGE_DRIVER=db

# --- Billing (Midtrans Snap) ---
# Sandbox keys start with "SB-Mid-server-", production keys with
# "Mid-server-" — the environment is selected by the prefix automatically.
# Without a key (dev), invoices are created without payment links.
# Also set the Payment Notification URL in the Midtrans dashboard to:
#   https://<host>/api/billing/midtrans
MIDTRANS_SERVER_KEY=

# --- AI claims check (optional) ---
# GROQ_API_KEY is free (console.groq.com); provider auto-detected.
GROQ_API_KEY=
# XAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_MODEL=
