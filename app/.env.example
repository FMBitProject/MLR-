# Copy to .env.local and fill in. .env* is gitignored.

# --- Database (required) ---
# Local dev (Docker Postgres):
#   DATABASE_URL=postgres://postgres:mlr@localhost:5433/mlr
# Production (Neon): use the POOLED connection string from the Neon dashboard,
# it ends in "-pooler" and includes ?sslmode=require
DATABASE_URL=

# Max connections per instance (Neon's pooler handles fan-out; keep this small)
# DB_POOL_MAX=5

# --- Auth (required in production) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- File storage ---
# Leave STORAGE_DRIVER=local for dev (writes to .data/uploads).
# Set STORAGE_DRIVER=s3 in production and fill the S3/R2 vars below.
STORAGE_DRIVER=local
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=            # e.g. https://<accountid>.r2.cloudflarestorage.com for Cloudflare R2
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- AI claims check (optional) ---
# GROQ_API_KEY is free (console.groq.com); provider auto-detected.
GROQ_API_KEY=
# XAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_MODEL=
